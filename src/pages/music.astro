---
import Layout from '../layouts/Layout.astro';
import albumCover from '../assets/album_photos/First Look.png';
---

<Layout title="Music — Cleanice" description="Cleanice — ню-метал. Дебютный альбом First Look.">
  <section class="music-hero">
    <div class="music-hero__bg">
      <img src={albumCover.src} alt="" class="music-hero__bg-img" loading="lazy" />
    </div>
    <div class="section-container">
      <p class="music-hero__label anim-fade-up delay-1" data-i18n="music_label">Discography</p>
      <h1 class="music-hero__title anim-blur-in delay-2" data-i18n="music_title">Music</h1>
    </div>
  </section>

  <section class="releases" id="releases">
    <div class="section-container">
      <div class="releases__header reveal">
        <h2 class="section-title" data-i18n="releases_title">Releases</h2>
        <div class="releases__filter" role="group" aria-label="Filter releases" id="filterGroup">
          <button class="filter-btn filter-btn--active" data-filter="all" aria-pressed="true" data-i18n="filter_all">All</button>
          <button class="filter-btn" data-filter="album" aria-pressed="false" data-i18n="filter_albums">Albums</button>
          <button class="filter-btn" data-filter="single" aria-pressed="false" data-i18n="filter_singles">Singles</button>
        </div>
      </div>

      <div class="releases__grid" id="releasesGrid">
        <article class="release-card release-card--featured reveal" data-type="album">
          <div class="release-card__cover">
            <img src={albumCover.src} alt="First Look — Cleanice" class="release-card__artwork-img" />
            <div class="release-card__overlay">
              <button class="release-card__play" aria-label="Play" id="openPlayer">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <polygon points="5 3 19 12 5 21 5 3"/>
                </svg>
              </button>
            </div>
          </div>
          <div class="release-card__info">
            <span class="release-card__type">Album</span>
            <h3 class="release-card__title">First Look</h3>
            <p class="release-card__date" data-i18n="album_date">2026 — Debut album</p>
          </div>
        </article>
      </div>

      <div class="not-found" id="notFound" style="display:none">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
          <line x1="8" y1="11" x2="14" y2="11"/>
        </svg>
        <p data-i18n="not_found">Nothing found yet</p>
      </div>
    </div>
  </section>

  <!-- Player Modal -->
  <div class="player-modal" id="playerModal">
    <div class="player-modal__backdrop" id="closePlayer"></div>
    <div class="player-modal__content">
      <button class="player-modal__close" id="closePlayerBtn" aria-label="Close">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
      <div class="player-modal__left">
        <img src={albumCover.src} alt="First Look" class="player-modal__cover" />
        <h3 class="player-modal__title">First Look</h3>
        <p class="player-modal__desc" data-i18n="player_desc">Debut album Cleanice. Nü metal.</p>
      </div>
      <div class="player-modal__right">
        <p class="player-modal__tracklist-label" data-i18n="player_tracklist">Tracklist</p>
        <div class="player-modal__tracks">
          <div class="track track--active">
            <span class="track__num">01</span>
            <div class="track__info">
              <span class="track__name">War</span>
              <span class="track__duration">3:42</span>
            </div>
          </div>
          <div class="track track--active">
            <span class="track__num">02</span>
            <div class="track__info">
              <span class="track__name">Slept</span>
              <span class="track__duration">--:--</span>
            </div>
          </div>
          <div class="track track--locked">
            <span class="track__num">03</span>
            <div class="track__info">
              <span class="track__name" data-i18n="coming_soon">Coming soon</span>
            </div>
            <svg class="track__lock" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <div class="track track--locked">
            <span class="track__num">04</span>
            <div class="track__info">
              <span class="track__name" data-i18n="coming_soon">Coming soon</span>
            </div>
            <svg class="track__lock" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <div class="track track--locked">
            <span class="track__num">05</span>
            <div class="track__info">
              <span class="track__name" data-i18n="coming_soon">Coming soon</span>
            </div>
            <svg class="track__lock" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Filter
  const filterGroup = document.getElementById('filterGroup')!;
  const grid = document.getElementById('releasesGrid')!;
  const notFound = document.getElementById('notFound')!;
  const cards = grid.querySelectorAll('.release-card');

  filterGroup.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.filter-btn');
    if (!btn) return;
    const filter = btn.dataset.filter;

    filterGroup.querySelectorAll('.filter-btn').forEach(b => {
      b.classList.remove('filter-btn--active');
      b.setAttribute('aria-pressed', 'false');
    });
    btn.classList.add('filter-btn--active');
    btn.setAttribute('aria-pressed', 'true');

    let found = 0;
    cards.forEach((card, i) => {
      const type = card.getAttribute('data-type');
      const show = filter === 'all' || type === filter;
      const el = card as HTMLElement;
      if (show) {
        el.style.display = '';
        el.style.opacity = '0';
        el.style.transform = 'translateY(20px)';
        setTimeout(() => {
          el.style.transition = 'opacity .4s ease-out, transform .4s ease-out';
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        }, i * 80);
        found++;
      } else {
        el.style.transition = 'opacity .25s ease-out';
        el.style.opacity = '0';
        setTimeout(() => { el.style.display = 'none'; }, 250);
      }
    });

    notFound.style.display = found === 0 ? 'flex' : 'none';
  });

  // Player modal
  const modal = document.getElementById('playerModal')!;
  document.getElementById('openPlayer')!.addEventListener('click', () => {
    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
  });
  document.getElementById('closePlayer')!.addEventListener('click', closeModal);
  document.getElementById('closePlayerBtn')!.addEventListener('click', closeModal);
  function closeModal() {
    modal.classList.remove('open');
    document.body.style.overflow = '';
  }

  // Parallax
  const musicBg = document.querySelector('.music-hero__bg-img') as HTMLElement;
  if (musicBg) {
    window.addEventListener('scroll', () => {
      musicBg.style.transform = `translateY(${window.scrollY * 0.25}px)`;
    }, { passive: true });
  }

  // Auto-scroll to releases on page load
  requestAnimationFrame(() => {
    const releases = document.getElementById('releases');
    if (releases) {
      releases.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });

  // Scroll to releases on hero hover
  const musicHero = document.querySelector('.music-hero');
  if (musicHero) {
    musicHero.addEventListener('mouseenter', () => {
      const releases = document.getElementById('releases');
      if (releases) {
        releases.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  }

  // Disable image saving
  document.querySelectorAll('img').forEach(img => {
    img.addEventListener('contextmenu', e => e.preventDefault());
    img.setAttribute('draggable', 'false');
    if (!img.hasAttribute('loading')) img.setAttribute('loading', 'lazy');
  });
</script>

<style>
  .music-hero {
    min-height: 50vh;
    display: flex;
    align-items: center;
    padding-top: 6rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .music-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .music-hero__bg-img {
    width: 100%;
    height: 140%;
    object-fit: cover;
    opacity: .12;
    filter: grayscale(1) contrast(1.3);
    will-change: transform;
  }

  .music-hero__label {
    font-size: .75rem;
    font-weight: 300;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 1;
  }

  .music-hero__title {
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 1;
    letter-spacing: 0.04em;
    position: relative;
    z-index: 1;
  }

  .releases { padding: 4rem 0 6rem; }

  .releases__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 3rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .releases__filter { display: flex; gap: .5rem; }

  .filter-btn {
    padding: .5rem 1rem;
    font-family: var(--font-sans);
    font-size: .8rem;
    font-weight: 300;
    color: var(--text-secondary);
    background: transparent;
    border: 1px solid transparent;
    border-radius: var(--radius-btn);
    cursor: pointer;
    transition: all .3s ease-out;
    letter-spacing: 0.04em;
  }

  .filter-btn:hover { color: var(--primary); }

  .filter-btn--active {
    color: var(--primary);
    border-color: var(--border);
    background: rgba(255,255,255,.03);
  }

  .releases__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .release-card {
    border-radius: var(--radius-card);
    background: rgba(255,255,255,.02);
    border: 1px solid var(--border);
    overflow: hidden;
    transition: all .35s cubic-bezier(.22,1,.36,1);
  }

  .release-card:hover {
    background: rgba(255,255,255,.04);
    border-color: rgba(255,255,255,.12);
    transform: translateY(-4px);
    box-shadow: 0 0 10px rgba(255,255,255,.08), 0 0 30px rgba(255,255,255,.04);
  }

  .release-card__cover {
    aspect-ratio: 1;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .release-card__artwork-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .6s cubic-bezier(.22,1,.36,1);
  }

  .release-card:hover .release-card__artwork-img { transform: scale(1.05); }

  .release-card__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,.5);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity .3s ease-out;
  }

  .release-card:hover .release-card__overlay { opacity: 1; }

  .release-card__play {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(255,255,255,.1);
    border: 1px solid rgba(255,255,255,.2);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all .3s cubic-bezier(.22,1,.36,1);
    backdrop-filter: blur(10px);
  }

  .release-card__play:hover {
    background: rgba(255,255,255,.2);
    box-shadow: 0 0 20px rgba(255,255,255,.2);
    transform: scale(1.1);
  }

  .release-card__play svg { margin-left: 2px; }

  .release-card__info { padding: 1.5rem; }

  .release-card__type {
    font-size: .7rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .release-card__title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 1.1rem;
    letter-spacing: 0.02em;
    margin: .5rem 0;
  }

  .release-card__date {
    font-size: .8rem;
    font-weight: 300;
    color: var(--text-secondary);
  }

  .release-card--featured {
    grid-column: 1 / -1;
    max-width: 400px;
    margin: 0 auto;
  }

  .release-card--featured .release-card__cover { aspect-ratio: 1; }

  /* Not found */
  .not-found {
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 4rem 0;
    color: var(--text-secondary);
    opacity: .5;
  }

  .not-found p {
    font-size: .9rem;
    font-weight: 300;
    letter-spacing: 0.04em;
  }

  /* Player Modal */
  .player-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity .3s ease-out;
  }

  .player-modal.open {
    opacity: 1;
    pointer-events: all;
  }

  .player-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,.7);
    backdrop-filter: blur(8px);
  }

  .player-modal__content {
    position: relative;
    display: flex;
    gap: 2rem;
    max-width: 640px;
    width: 90vw;
    max-height: 85vh;
    background: rgba(18,18,18,.95);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    padding: 2rem;
    backdrop-filter: blur(24px);
    overflow-y: auto;
    transform: translateY(20px) scale(.97);
    transition: transform .4s cubic-bezier(.22,1,.36,1);
  }
  body.light .player-modal__content {
    background: rgba(245,243,239,.95);
  }

  .player-modal.open .player-modal__content {
    transform: translateY(0) scale(1);
  }

  .player-modal__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    color: var(--text-secondary);
    cursor: pointer;
    padding: .5rem;
    border-radius: 50%;
    transition: color .3s ease-out, background .3s ease-out;
  }

  .player-modal__close:hover {
    color: var(--primary);
    background: rgba(255,255,255,.05);
  }

  .player-modal__left {
    flex: 0 0 200px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .player-modal__cover {
    width: 200px;
    height: 200px;
    border-radius: var(--radius-card);
    object-fit: cover;
  }

  .player-modal__title {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 400;
    text-align: center;
  }

  .player-modal__desc {
    font-size: .78rem;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.6;
    text-align: center;
  }

  .player-modal__right {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }

  .player-modal__tracklist-label {
    font-size: .7rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: .25rem;
  }

  .player-modal__tracks {
    display: flex;
    flex-direction: column;
    gap: .35rem;
  }

  .track {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .6rem .75rem;
    border-radius: var(--radius-btn);
    transition: background .3s ease-out;
  }

  .track--active {
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.08);
  }

  .track--locked {
    opacity: .35;
    filter: blur(1px);
    pointer-events: none;
  }

  .track__num {
    font-size: .75rem;
    font-weight: 300;
    color: var(--text-secondary);
    min-width: 1.5rem;
  }

  .track__info {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .track__name {
    font-size: .85rem;
    font-weight: 300;
  }

  .track__duration {
    font-size: .75rem;
    font-weight: 300;
    color: var(--text-secondary);
  }

  .track__lock {
    color: var(--text-secondary);
    opacity: .5;
  }

  @media (max-width: 600px) {
    .player-modal__content { flex-direction: column; align-items: center; }
    .player-modal__left { flex: none; }
    .releases__header { flex-direction: column; align-items: flex-start; }
  }
</style>
