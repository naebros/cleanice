---
import Layout from '../layouts/Layout.astro';
import bandPhoto from '../assets/band-photo.png';
---

<Layout title="Cleanice">
  <a href="#featured" class="sr-only">Skip to content</a>

  <section class="hero" id="content" style={`--hero-bg: url('${bandPhoto.src}')`}>
    <div class="hero__bg"></div>
    <div class="hero__glow"></div>
    <div class="hero__content">
      <p class="hero__label fade-in" style="--delay:.2s" data-i18n="hero_label">New album in progress</p>
      <h1 class="hero__title">
        {['C','l','e','a','n','i','c','e'].map((letter, i) => (
          <span class="hero__title-letter" style={`animation-delay:${.3 + i * .06}s`}>{letter}</span>
        ))}
      </h1>
      <p class="hero__sub fade-in" style="--delay:.7s" data-i18n="hero_sub">Nü metal. First Look — coming soon</p>
      <div class="hero__actions fade-in" style="--delay:.9s">
        <a href="/music" class="btn btn--primary" data-i18n="hero_listen">Listen now</a>
        <a href="/about" class="btn btn--ghost" data-i18n="hero_about">About us</a>
      </div>
    </div>
    <a href="#featured" class="hero__scroll fade-in" style="--delay:1.2s" aria-label="Scroll down">
      <div class="hero__scroll-line"></div>
    </a>
  </section>

  <section class="featured" id="featured">
    <div class="section-container">
      <div class="featured__grid">
        <a href="/music" class="card reveal">
          <div class="card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="5.5" cy="17.5" r="2.5"/><circle cx="17.5" cy="15.5" r="2.5"/><path d="M8 17V5l12-2v12"/></svg>
          </div>
          <h3 class="card__title" data-i18n="card_music_title">First Look</h3>
          <p class="card__text" data-i18n="card_music_text">Our debut album is in the works. Stay tuned.</p>
          <span class="card__arrow">&rarr;</span>
        </a>
        <a href="/about" class="card reveal" style="--delay:.1s">
          <div class="card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="card__title" data-i18n="card_about_title">About Us</h3>
          <p class="card__text" data-i18n="card_about_text">The story behind the sound. Who we are and what drives us.</p>
          <span class="card__arrow">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <section class="cta">
    <div class="section-container">
      <div class="cta__inner reveal--blur">
        <h2 class="cta__title" data-i18n="cta_title">Stay in the loop</h2>
        <p class="cta__text" data-i18n="cta_text">Get notified about new releases, shows, and exclusive content.</p>
        <form class="cta__form" id="subscribeForm">
          <input type="email" placeholder="your@email.com" class="cta__input" id="subscribeEmail" data-i18n-placeholder="cta_placeholder" required />
          <button type="submit" class="btn btn--primary" id="subscribeBtn" data-i18n="cta_btn">Subscribe</button>
        </form>
        <p class="cta__message" id="subscribeMessage"></p>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { getLang, t } from '../scripts/i18n';

  const form = document.getElementById('subscribeForm') as HTMLFormElement;
  const emailInput = document.getElementById('subscribeEmail') as HTMLInputElement;
  const btn = document.getElementById('subscribeBtn') as HTMLButtonElement;
  const msg = document.getElementById('subscribeMessage') as HTMLParagraphElement;
  const FORMSPREE_ID = 'maqrwrvj';

  function isValidEmail(email: string) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email); }
  function getSubscribed(): string[] { try { return JSON.parse(localStorage.getItem('cleanice_subscribers') || '[]'); } catch { return []; } }

  function showMsg(text: string, ok: boolean) {
    msg.textContent = text;
    msg.style.color = ok ? 'var(--text-secondary)' : '#ff6464';
    msg.style.opacity = '1';
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = emailInput.value.trim();

    if (!isValidEmail(email)) { showMsg(t('cta_invalid'), false); return; }
    const subs = getSubscribed();
    if (subs.includes(email)) { showMsg(t('cta_already'), true); emailInput.value = ''; return; }

    btn.textContent = '...'; btn.setAttribute('disabled', 'true');
    if (FORMSPREE_ID) {
      try {
        const res = await fetch(`https://formspree.io/f/${FORMSPREE_ID}`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ email }) });
        if (!res.ok) throw new Error();
      } catch { showMsg(t('cta_error'), false); btn.textContent = t('cta_btn'); btn.removeAttribute('disabled'); return; }
    }
    subs.push(email); localStorage.setItem('cleanice_subscribers', JSON.stringify(subs));
    showMsg(t('cta_subscribed'), true);
    emailInput.value = ''; btn.textContent = t('cta_btn'); btn.removeAttribute('disabled');
  });
</script>

<style>
  /* Hero */
  .hero { min-height: 100vh; min-height: 100dvh; display: flex; align-items: center; justify-content: center; position: relative; padding: 6rem 1.5rem 3rem; text-align: center; overflow: hidden; }
  .hero__bg { position: absolute; inset: 0; z-index: 0; background-image: var(--hero-bg); background-position: center; background-repeat: no-repeat; background-size: cover; background-attachment: fixed; opacity: .08; filter: grayscale(1) contrast(1.2); mix-blend-mode: screen; }
  body.light .hero__bg { opacity: .06; filter: grayscale(1) contrast(.8); mix-blend-mode: multiply; }
  .hero__glow { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: min(500px, 80vw); aspect-ratio: 1; border-radius: 50%; background: radial-gradient(circle, rgba(255,255,255,.08) 0%, transparent 70%); animation: glowPulse 6s ease-in-out infinite; pointer-events: none; }
  body.light .hero__glow { background: radial-gradient(circle, rgba(0,0,0,.04) 0%, transparent 70%); }
  .hero__content { position: relative; z-index: 1; }
  .hero__title { font-family: var(--font-serif); font-weight: 300; font-size: clamp(3.5rem, 12vw, 10rem); line-height: .9; letter-spacing: .04em; margin-bottom: 1.5rem; display: flex; justify-content: center; }
  .hero__title-letter { display: inline-block; opacity: 0; transform: translateY(60px) scale(.8); animation: letterWave .8s cubic-bezier(.34,1.56,.64,1) forwards; transition: color .25s ease-out, transform .4s cubic-bezier(.34,1.56,.64,1); user-select: none; }
  @keyframes letterWave { 0% { opacity: 0; transform: translateY(60px) scale(.8) rotateX(40deg); } 60% { opacity: 1; transform: translateY(-8px) scale(1.02) rotateX(-5deg); } 100% { opacity: 1; transform: translateY(0) scale(1) rotateX(0); } }
  .hero__title-letter:hover { color: var(--primary); transform: translateY(-8px) scale(1.08); text-shadow: 0 0 20px rgba(255,255,255,.4), 0 0 40px rgba(255,255,255,.15); }
  body.light .hero__title-letter:hover { text-shadow: 0 0 20px rgba(0,0,0,.1), 0 0 40px rgba(0,0,0,.05); }
  .hero__label { font-size: .7rem; font-weight: 300; letter-spacing: .15em; text-transform: uppercase; color: var(--text-secondary); margin-bottom: 1.5rem; }
  .hero__sub { font-size: .9rem; font-weight: 300; color: var(--text-secondary); letter-spacing: .08em; margin-bottom: 2.5rem; }
  .hero__actions { display: flex; gap: .75rem; justify-content: center; flex-wrap: wrap; }
  .hero__scroll { position: absolute; bottom: 1.5rem; left: 50%; transform: translateX(-50%); display: block; transition: transform .3s ease-out; }
  .hero__scroll:hover { transform: translateX(-50%) translateY(4px); }
  .hero__scroll-line { width: 1px; height: 50px; background: linear-gradient(to bottom, rgba(255,255,255,.3), transparent); animation: scrollPulse 2s ease-in-out infinite; }
  body.light .hero__scroll-line { background: linear-gradient(to bottom, rgba(0,0,0,.2), transparent); }
  @keyframes scrollPulse { 0%, 100% { opacity: .3; transform: scaleY(1); } 50% { opacity: .7; transform: scaleY(1.3); } }

  /* Featured */
  .featured { padding: 4rem 0; }
  .featured__grid { display: grid; grid-template-columns: 1fr; gap: 1rem; }

  .card {
    display: block; padding: 1.5rem; border-radius: var(--radius-card);
    background: var(--card-bg); border: 1px solid var(--border);
    backdrop-filter: blur(18px); position: relative; overflow: hidden;
    transition: transform .5s cubic-bezier(.23,1,.32,1), box-shadow .5s cubic-bezier(.23,1,.32,1), border-color .4s ease-out, background .4s ease-out;
  }
  .card:hover { transform: translateY(-6px) scale(1.01); box-shadow: 0 20px 60px rgba(255,255,255,.06), 0 0 0 1px rgba(255,255,255,.08); border-color: rgba(255,255,255,.15); background: rgba(255,255,255,.04); }
  body.light .card:hover { box-shadow: 0 20px 60px rgba(0,0,0,.06), 0 0 0 1px rgba(0,0,0,.08); border-color: rgba(0,0,0,.15); background: rgba(0,0,0,.04); }
  .card__icon { margin-bottom: 1rem; color: var(--text-secondary); transition: color .3s ease-out; }
  .card:hover .card__icon { color: var(--primary); }
  .card__title { font-family: var(--font-serif); font-weight: 400; font-size: 1.2rem; letter-spacing: .02em; margin-bottom: .5rem; }
  .card__text { font-size: .82rem; font-weight: 300; color: var(--text-secondary); line-height: 1.7; margin-bottom: 1rem; }
  .card__arrow { display: inline-block; font-size: 1.1rem; color: var(--text-secondary); transition: color .3s ease-out, transform .3s cubic-bezier(.34,1.56,.64,1); }
  .card:hover .card__arrow { color: var(--primary); transform: translateX(6px); }

  /* CTA */
  .cta { padding: 4rem 0; }
  .cta__inner { text-align: center; max-width: 500px; margin: 0 auto; padding: 2rem 1.5rem; border-radius: var(--radius-lg); background: var(--card-bg); border: 1px solid var(--border); backdrop-filter: blur(18px); }
  .cta__title { font-family: var(--font-serif); font-weight: 300; font-size: 1.5rem; letter-spacing: .02em; margin-bottom: .5rem; }
  .cta__text { font-size: .82rem; font-weight: 300; color: var(--text-secondary); line-height: 1.7; margin-bottom: 1.5rem; }
  .cta__form { display: flex; gap: .5rem; }
  .cta__input { flex: 1; padding: .75rem 1rem; font-family: var(--font-sans); font-size: .82rem; font-weight: 300; color: var(--primary); background: rgba(255,255,255,.03); border: 1px solid var(--border); border-radius: var(--radius-input); outline: none; transition: border-color .3s ease-out, box-shadow .3s ease-out; min-width: 0; }
  body.light .cta__input { background: rgba(0,0,0,.03); }
  .cta__input::placeholder { color: rgba(255,255,255,.25); }
  body.light .cta__input::placeholder { color: rgba(0,0,0,.25); }
  .cta__input:focus { border-color: rgba(255,255,255,.25); box-shadow: 0 0 0 3px rgba(255,255,255,.05); background: rgba(255,255,255,.05); }
  body.light .cta__input:focus { border-color: rgba(0,0,0,.2); box-shadow: 0 0 0 3px rgba(0,0,0,.04); background: rgba(0,0,0,.05); }
  .cta__message { margin-top: .75rem; font-size: .78rem; font-weight: 300; opacity: 0; transition: opacity .3s ease-out; }

  @media (min-width: 768px) {
    .featured { padding: 6rem 0; }
    .featured__grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
    .card { padding: 2rem; }
    .cta { padding: 6rem 0; }
    .cta__inner { padding: 3rem; }
  }
</style>
