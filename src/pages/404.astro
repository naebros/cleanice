---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Cleanice" description="Page not found">
  <section class="notfound">
    <div class="section-container">
      <p class="notfound__code anim-blur-in">404</p>
      <h1 class="notfound__title anim-fade-up delay-2">Lost in silence</h1>
      <p class="notfound__text anim-fade-up delay-3">This page doesn't exist. Maybe it was never meant to.</p>
      <a href="/" class="btn btn--primary anim-fade-up delay-4">Back to home</a>
    </div>
  </section>
</Layout>

<style>
  .notfound {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .notfound__code {
    font-family: var(--font-serif);
    font-size: clamp(6rem, 20vw, 14rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,.06);
    margin-bottom: 1rem;
  }

  .notfound__title {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 300;
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
  }

  .notfound__text {
    font-size: .9rem;
    font-weight: 300;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.7;
  }
</style>
