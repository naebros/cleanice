---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Cleanice" description="Page not found" hideNav={true}>
  <section class="notfound">
    <div class="section-container">
      <h1 class="notfound__code anim-blur-in">404</h1>
      <p class="notfound__title anim-fade-up delay-2">Lost in silence</p>
      <p class="notfound__text anim-fade-up delay-3">This page doesn't exist. Maybe it was never meant to.</p>
      <a href="/" class="btn btn--primary anim-fade-up delay-4">Back to home</a>
    </div>
  </section>
</Layout>

<style>
  .notfound {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .notfound__code {
    font-family: var(--font-serif);
    font-size: clamp(4rem, 12vw, 10rem);
    font-weight: 300;
    line-height: 0.9;
    letter-spacing: 0.04em;
    margin-bottom: 1.5rem;
  }

  .notfound__title {
    font-size: 1rem;
    font-weight: 300;
    color: var(--text-secondary);
    letter-spacing: 0.08em;
    margin-bottom: .75rem;
  }

  .notfound__text {
    font-size: .85rem;
    font-weight: 300;
    color: rgba(255,255,255,.25);
    margin-bottom: 2rem;
    line-height: 1.7;
  }
</style>
