---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  hideNav?: boolean;
  hideFooter?: boolean;
}

const { title, description = 'Cleanice — ню-метал', hideNav = false, hideFooter = false } = Astro.props;
const currentPath = Astro.url.pathname;
const year = new Date().getFullYear();
const canonicalURL = new URL(currentPath, Astro.site || 'https://cleanice.net').href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#090909" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Cleanice" />
    <meta property="og:image" content="https://cleanice.net/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="stylesheet" href="/fonts/fonts.css" />
    <title>{title}</title>
  </head>
  <body>
    <script is:inline>
      (function(){
        var y = new Date().getFullYear();
        var lang = localStorage.getItem('cleanice_lang') || 'en';
        if (lang === 'ru') document.documentElement.lang = 'ru';
        var d = {
          en: {
            nav_home:'Home',nav_about:'About',nav_music:'Music',
            hero_label:'New album in progress',hero_sub:'Nü metal. First Look — coming soon',
            hero_listen:'Listen now',hero_about:'About us',
            card_music_title:'First Look',card_music_text:'Our debut album is in the works. Stay tuned.',
            card_about_title:'About Us',card_about_text:'The story behind the sound. Who we are and what drives us.',
            cta_title:'Stay in the loop',cta_text:'Get notified about new releases, shows, and exclusive content.',
            cta_placeholder:'your@email.com',cta_btn:'Subscribe',
            about_label:'Who we are',about_title:'About',about_sub:'Nü metal. Contrast. Purity.',
            about_story_title:'The Story',about_story_p1:'It all started with a guitar and a dream. Senu, a 14-year-old guitarist, had always imagined creating his own album \u2014 a world of sound built from scratch. One day he called his friend Nikita, a 15-year-old bassist, and said: "Let\'s make something real." That conversation became Cleanice.',
            about_story_p2:'Now we\'re writing our debut album "First Look" \u2014 our first look at how nü metal should sound in '+y+'. It\'s still taking shape, note by note, but every track carries the weight of that first conversation.',
            values_title:'What Drives Us',
            v1_title:'Contrast',v1_text:'Heaviness and purity. Noise and silence. We live on the edge of two extremes.',
            v2_title:'Energy',v2_text:'Nü metal is movement. Every track should make your body react.',
            v3_title:'Purity',v3_text:'Cleanice isn\'t just a name. We filter sound to its most essential.',
            v4_title:'Freshness',v4_text:'First album \u2014 first look. We don\'t copy, we create our own sound.',
            members_title:'Members',m1_role:'Vocals / Guitar / Frontman / DJ',m2_role:'Bass / Keys',
            music_label:'Discography',music_title:'Music',
            releases_title:'Releases',filter_all:'All',filter_albums:'Albums',filter_singles:'Singles',
            album_date:y+' \u2014 In progress',not_found:'Nothing found yet',
            player_tracklist:'Tracklist',player_desc:'Our debut album is currently in the writing process. Nü metal, '+y+'. Hard but clean.',
            coming_soon:'Coming soon',
            about_quote:"We don't make music to fill silence. We make silence to fill music.",
            not_found_title:'Lost in silence',not_found_text:"This page doesn't exist. Maybe it was never meant to.",not_found_btn:'Back to home',
            footer_copy:'© '+y+' Cleanice'
          },
          ru: {
            nav_home:'Главная',nav_about:'О нас',nav_music:'Музыка',
            hero_label:'Альбом в процессе',hero_sub:'Ню-метал. First Look — скоро',
            hero_listen:'Слушать',hero_about:'О нас',
            card_music_title:'First Look',card_music_text:'Наш дебютный альбом в работе. Следите за обновлениями.',
            card_about_title:'О нас',card_about_text:'История за звуком. Кто мы и что нами движет.',
            cta_title:'Будь в курсе',cta_text:'Получай уведомления о новых релизах, шоу и эксклюзивном контенте.',
            cta_placeholder:'ваш@email.com',cta_btn:'Подписаться',
            about_label:'Кто мы',about_title:'О нас',about_sub:'Ню-метал. Контраст. Чистота.',
            about_story_title:'История',about_story_p1:'Всё началось с гитары и мечты. Сене — 14-летнему гитаристу — всегда хотелось записать собственный альбом, создать мир звука с нуля. Однажды он позвонил своему другу Никите — 15-летнему басисту — и сказал: "Давай сделаем что-то настоящее." Этот разговор стал началом Cleanice.',
            about_story_p2:'Сейчас мы пишем дебютный альбом "First Look" — наш первый взгляд на то, как должен звучать ню-метал в '+y+'-м. Он ещё создаётся, нота за нотой, но каждый трек несёт в себе вес того самого разговора.',
            values_title:'Что нами движет',
            v1_title:'Контраст',v1_text:'Тяжесть и чистота. Шум и тишина. Мы живём на границе двух крайностей.',
            v2_title:'Энергия',v2_text:'Ню-метал — это движение. Каждый трек должен заставить тело реагировать.',
            v3_title:'Чистота',v3_text:'Cleanice — не просто название. Мы фильтруем звук до самого главного.',
            v4_title:'Свежесть',v4_text:'Первый альбом — первый взгляд. Мы не копируем, мы создаём свой звук.',
            members_title:'Участники',m1_role:'Вокал / Гитара / Фронтмен / DJ',m2_role:'Бас / Клавишные',
            music_label:'Дискография',music_title:'Музыка',
            releases_title:'Релизы',filter_all:'Все',filter_albums:'Альбомы',filter_singles:'Синглы',
            album_date:y+' — В процессе',not_found:'Ничего не найдено',
            player_tracklist:'Трек-лист',player_desc:'Наш дебютный альбом сейчас в процессе написания. Ню-метал, '+y+'. Жёстко, но чисто.',
            coming_soon:'Скоро',
            about_quote:'Мы не делаем музыку, чтобы заполнить тишину. Мы делаем тишину, чтобы наполнить музыкой.',
            not_found_title:'Потерялись в тишине',not_found_text:'Этой страницы не существует. Может, она никогда и не была предназначена.',not_found_btn:'На главную',
            footer_copy:'© '+y+' Cleanice'
          }
        };
        function apply(el) {
          var key = el.getAttribute && el.getAttribute('data-i18n');
          if (key && d[lang] && d[lang][key]) el.textContent = d[lang][key];
          var ph = el.getAttribute && el.getAttribute('data-i18n-placeholder');
          if (ph && d[lang] && d[lang][ph]) el.placeholder = d[lang][ph];
        }
        function scan(root) {
          if (root.querySelectorAll) {
            root.querySelectorAll('[data-i18n],[data-i18n-placeholder]').forEach(apply);
          }
        }
        if (lang !== 'en') {
          var obs = new MutationObserver(function(mutations) {
            for (var i = 0; i < mutations.length; i++) {
              var nodes = mutations[i].addedNodes;
              for (var j = 0; j < nodes.length; j++) {
                var n = nodes[j];
                if (n.nodeType !== 1) continue;
                apply(n);
                scan(n);
              }
            }
          });
          obs.observe(document.body, { childList: true, subtree: true });
          window.__i18nObs = obs;
        }
        window.__i18nLang = lang;
        window.__i18nData = d;
        window.__i18nReplaceYear = function(s) { return s.replace(/\{year\}/g, String(y)); };
        var theme = localStorage.getItem('cleanice_theme') || 'dark';
        if (theme === 'light') document.body.classList.add('light');
        var mc = theme === 'light' ? '#F5F3EF' : '#090909';
        var meta = document.querySelector('meta[name="theme-color"]');
        if (meta) meta.setAttribute('content', mc);
      })();
    </script>
    <div class="page-transition"></div>
    <div class="grain"></div>
    <div class="glow glow--top"></div>

    {!hideNav && (
    <nav class="nav" id="nav">
      <button class="nav__switcher" id="langSwitcher" aria-label="Language: English">EN</button>
      <div class="nav__links">
        <a href="/" class:list={["nav__link", { "nav__link--active": currentPath === "/" }]} aria-current={currentPath === "/" ? "page" : undefined} data-i18n="nav_home">Home</a>
        <a href="/about" class:list={["nav__link", { "nav__link--active": currentPath === "/about/" || currentPath === "/about" }]} aria-current={currentPath === "/about/" || currentPath === "/about" ? "page" : undefined} data-i18n="nav_about">About</a>
        <a href="/music" class:list={["nav__link", { "nav__link--active": currentPath === "/music/" || currentPath === "/music" }]} aria-current={currentPath === "/music/" || currentPath === "/music" ? "page" : undefined} data-i18n="nav_music">Music</a>
      </div>
      <button class="nav__switcher" id="themeSwitcher" aria-label="Switch theme">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="icon-sun"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="icon-moon"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </nav>
    )}

    <main>
      <slot />
    </main>

    {!hideFooter && (
    <footer class="footer">
      <div class="footer__inner">
        <span class="footer__logo-text">CLEANICE</span>
        <span class="footer__copy">&copy; {year} Cleanice</span>
      </div>
    </footer>
    )}

    <script>
      import { initI18n } from '../scripts/i18n';
      import { initSmoothScroll } from '../scripts/parallax';
      initI18n();
      initSmoothScroll();
    </script>

    <script>
      const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
      let prefersReducedMotion = motionQuery.matches;
      motionQuery.addEventListener('change', () => { prefersReducedMotion = motionQuery.matches; });

      // Page transition: fade out overlay on load
      const pt = document.querySelector('.page-transition');
      if (pt) {
        if (prefersReducedMotion) { pt.style.display = 'none'; }
        else { requestAnimationFrame(() => { pt.classList.add('loaded'); }); }
      }

      // Scroll reveal
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.reveal, .reveal--blur, .reveal--scale').forEach(el => {
        if (prefersReducedMotion) { el.classList.add('is-visible'); }
        else { observer.observe(el); }
      });

      // Image protection
      document.addEventListener('contextmenu', e => { if (e.target.tagName === 'IMG') e.preventDefault(); });
      document.addEventListener('dragstart', e => { if (e.target.tagName === 'IMG') e.preventDefault(); });

      // Page transitions
      document.addEventListener('click', (e) => {
        const link = (e.target as HTMLElement).closest('a[href^="/"]');
        if (!link) return;
        const href = link.getAttribute('href');
        const current = window.location.pathname.replace(/\/$/, '') || '/';
        const target = (href || '').replace(/\/$/, '') || '/';
        if (target === current) return;
        e.preventDefault();
        if (prefersReducedMotion) { window.location.href = href!; return; }
        const t = document.querySelector('.page-transition');
        if (t) { t.classList.add('active'); }
        setTimeout(() => { window.scrollTo(0, 0); window.location.href = href!; }, 350);
      });
    </script>
  </body>
</html>
