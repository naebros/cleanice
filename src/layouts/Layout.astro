---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Cleanice — ню-метал. First Look — debut album 2026' } = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <div class="grain"></div>
    <div class="glow glow--top"></div>
    <nav class="nav" id="nav">
      <div class="nav__links">
        <a href="/" class:list={["nav__link", { "nav__link--active": currentPath === "/" }]}>Home</a>
        <a href="/about" class:list={["nav__link", { "nav__link--active": currentPath === "/about/" || currentPath === "/about" }]}>About</a>
        <a href="/music" class:list={["nav__link", { "nav__link--active": currentPath === "/music/" || currentPath === "/music" }]}>Music</a>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer class="footer">
      <div class="footer__inner">
        <span class="footer__logo-text">CLEANICE</span>
        <div class="footer__links">
          <a href="https://instagram.com" target="_blank" rel="noopener">Instagram</a>
        </div>
        <span class="footer__copy">&copy; {new Date().getFullYear()} Cleanice</span>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --background: #090909;
    --primary: #FFFFFF;
    --text: #F5F5F5;
    --text-secondary: #B5B5B5;
    --border: rgba(255,255,255,.08);

    --radius-card: 18px;
    --radius-btn: 12px;
    --radius-input: 10px;
    --radius-lg: 24px;

    --font-serif: 'Instrument Serif', Georgia, serif;
    --font-sans: 'Inter', system-ui, sans-serif;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-family: var(--font-sans);
    background: var(--background);
    color: var(--text);
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100vh;
    background: radial-gradient(circle at 50% 0%, #121212 0%, #090909 55%, #040404 100%);
    overflow-x: hidden;
    position: relative;
  }

  main {
    min-height: calc(100vh - 200px);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .section-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Grain overlay */
  .grain {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    opacity: 0.1;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 128px 128px;
  }

  /* Ambient glow */
  .glow {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
  }

  .glow--top {
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 600px;
    background: radial-gradient(circle, rgba(255,255,255,.06) 0%, transparent 70%);
    animation: glowPulse 6s ease-in-out infinite;
  }

  @keyframes glowPulse {
    0%, 100% { opacity: .6; }
    50% { opacity: 1; }
  }

  /* Navigation — Dynamic Island */
  .nav {
    position: fixed;
    top: 1rem;
    left: 50%;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: .85rem 2.5rem;
    width: min(90vw, 380px);
    border-radius: 100px;
    backdrop-filter: blur(24px) saturate(1.4);
    background: rgba(18,18,18,.75);
    border: 1px solid rgba(255,255,255,.08);
    box-shadow: 0 8px 32px rgba(0,0,0,.4), 0 0 0 1px rgba(255,255,255,.04) inset;
    animation: navAppear .6s cubic-bezier(.22,1,.36,1) both;
    cursor: pointer;
    transition: transform .4s cubic-bezier(.34,1.56,.64,1);
  }

  .nav:active {
    transform: translateX(-50%) scale(.96);
  }

  @keyframes navAppear {
    from { opacity: 0; transform: translateX(-50%) translateY(-12px) scale(.95); }
    to { opacity: 1; transform: translateX(-50%) translateY(0) scale(1); }
  }

  @keyframes navBounce {
    0% { transform: translateX(-50%) scale(1); }
    30% { transform: translateX(-50%) scale(.92); }
    60% { transform: translateX(-50%) scale(1.04); }
    100% { transform: translateX(-50%) scale(1); }
  }

  .nav.bounce {
    animation: navBounce .5s cubic-bezier(.34,1.56,.64,1);
  }

  .nav__links {
    display: flex;
    gap: 2rem;
  }

  .nav__link {
    font-size: .75rem;
    font-weight: 300;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-secondary);
    transition: color .3s ease-out, text-shadow .3s ease-out;
    position: relative;
    padding: .15rem 0;
  }

  .nav__link--active {
    color: var(--primary);
  }

  .nav__link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--primary);
    transition: width .3s cubic-bezier(.22,1,.36,1);
  }

  .nav__link--active::after {
    width: 100%;
  }

  .nav__link:hover {
    color: var(--primary);
    text-shadow: 0 0 16px rgba(255,255,255,.2);
  }

  .nav__link:hover::after {
    width: 100%;
  }

  /* Buttons — global */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: .85rem 2rem;
    font-family: var(--font-sans);
    font-size: .85rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    border-radius: var(--radius-btn);
    cursor: pointer;
    transition: all .3s cubic-bezier(.22,1,.36,1);
    border: none;
    text-decoration: none;
  }

  .btn--primary {
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.12);
    color: white;
  }

  .btn--primary:hover {
    background: rgba(255,255,255,.1);
    box-shadow: 0 0 30px rgba(255,255,255,.15);
    border-color: rgba(255,255,255,.2);
  }

  .btn--ghost {
    background: transparent;
    color: var(--text-secondary);
  }

  .btn--ghost:hover {
    color: var(--primary);
    text-shadow: 0 0 16px rgba(255,255,255,.3);
  }

  /* Footer logo */
  .footer__logo-text {
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: .9rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--text-secondary);
    opacity: .5;
  }

  /* Footer */
  .footer {
    border-top: 1px solid var(--border);
    padding: 3rem 5vw;
  }

  .footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .footer__links {
    display: flex;
    gap: 2rem;
  }

  .footer__links a {
    font-size: .8rem;
    font-weight: 300;
    color: var(--text-secondary);
    letter-spacing: 0.04em;
    transition: color .3s ease-out, text-shadow .3s ease-out;
  }

  .footer__links a:hover {
    color: var(--primary);
    text-shadow: 0 0 12px rgba(255,255,255,.3);
  }

  .footer__copy {
    font-size: .75rem;
    color: rgba(255,255,255,.25);
    letter-spacing: 0.04em;
  }

  /* Animations */
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes blurIn {
    from { opacity: 0; filter: blur(12px); }
    to { opacity: 1; filter: blur(0); }
  }

  /* Scroll reveal */
  .reveal {
    opacity: 0;
    transform: translateY(50px) scale(.97);
    transition: opacity .7s cubic-bezier(.22,1,.36,1), transform .7s cubic-bezier(.22,1,.36,1);
  }

  .reveal--blur {
    opacity: 0;
    filter: blur(12px);
    transition: opacity .8s cubic-bezier(.22,1,.36,1), filter .8s cubic-bezier(.22,1,.36,1);
  }

  .reveal--scale {
    opacity: 0;
    transform: scale(.96);
    transition: opacity .7s cubic-bezier(.22,1,.36,1), transform .7s cubic-bezier(.22,1,.36,1);
  }

  .reveal.is-visible,
  .reveal--blur.is-visible,
  .reveal--scale.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
  }

  /* Entrance animations (on load) */
  .anim-fade-in {
    animation: fadeIn .6s cubic-bezier(.22,1,.36,1) both;
  }

  .anim-fade-up {
    animation: fadeUp .7s cubic-bezier(.22,1,.36,1) both;
  }

  .anim-blur-in {
    animation: blurIn .9s cubic-bezier(.22,1,.36,1) both;
  }

  .delay-1 { animation-delay: .1s; }
  .delay-2 { animation-delay: .2s; }
  .delay-3 { animation-delay: .3s; }
  .delay-4 { animation-delay: .4s; }
  .delay-5 { animation-delay: .5s; }
  .delay-6 { animation-delay: .6s; }
  .delay-7 { animation-delay: .7s; }
  .delay-8 { animation-delay: .8s; }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--background); }
  ::-webkit-scrollbar-thumb { background: rgba(255,255,255,.15); border-radius: 2px; }
  ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,.25); }

  @media (max-width: 768px) {
    .nav { padding: .7rem 1.2rem; width: min(92vw, 360px); }
    .nav__links { gap: 1.2rem; }
    .nav__link { font-size: .7rem; }
    .footer { padding: 2rem 1.5rem; }
  }
</style>

<script>
  const nav = document.getElementById('nav');

  // Nav bounce on click
  nav.addEventListener('click', () => {
    nav.classList.remove('bounce');
    void nav.offsetWidth;
    nav.classList.add('bounce');
  });

  nav.addEventListener('animationend', () => {
    nav.classList.remove('bounce');
  });

  // Scroll reveal
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, {
    threshold: 0.15,
    rootMargin: '0px 0px -40px 0px'
  });

  document.querySelectorAll('.reveal, .reveal--blur, .reveal--scale').forEach((el) => {
    observer.observe(el);
  });
</script>
