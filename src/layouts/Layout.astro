---
interface Props {
  title: string;
  description?: string;
  hideNav?: boolean;
  hideFooter?: boolean;
}

const { title, description = 'Cleanice — ню-метал', hideNav = false, hideFooter = false } = Astro.props;
const currentPath = Astro.url.pathname;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#090909" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <div class="page-transition"></div>
    <div class="grain"></div>
    <div class="glow glow--top"></div>

    {!hideNav && (
    <nav class="nav" id="nav">
      <button class="nav__switcher" id="langSwitcher" aria-label="Switch language">EN</button>
      <div class="nav__links">
        <a href="/" class:list={["nav__link", { "nav__link--active": currentPath === "/" }]} data-i18n="nav_home">Home</a>
        <a href="/about" class:list={["nav__link", { "nav__link--active": currentPath === "/about/" || currentPath === "/about" }]} data-i18n="nav_about">About</a>
        <a href="/music" class:list={["nav__link", { "nav__link--active": currentPath === "/music/" || currentPath === "/music" }]} data-i18n="nav_music">Music</a>
      </div>
      <button class="nav__switcher" id="themeSwitcher" aria-label="Switch theme">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="icon-sun"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="icon-moon"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </nav>
    )}

    <main>
      <slot />
    </main>

    {!hideFooter && (
    <footer class="footer">
      <div class="footer__inner">
        <span class="footer__logo-text">CLEANICE</span>
        <div class="footer__links">
          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer">Instagram</a>
        </div>
        <span class="footer__copy">&copy; {year} Cleanice</span>
      </div>
    </footer>
    )}

    <script is:inline define:vars={{ year }}>
      const i18n = {
        en: {
          nav_home: 'Home', nav_about: 'About', nav_music: 'Music',
          hero_label: 'New album in progress', hero_sub: 'Nü metal. First Look — coming soon',
          hero_listen: 'Listen now', hero_about: 'About us',
          card_music_title: 'First Look', card_music_text: 'Our debut album is in the works. Stay tuned.',
          card_about_title: 'About Us', card_about_text: 'The story behind the sound. Who we are and what drives us.',
          cta_title: 'Stay in the loop', cta_text: 'Get notified about new releases, shows, and exclusive content.',
          cta_placeholder: 'your@email.com', cta_btn: 'Subscribe',
          cta_subscribed: 'Subscribed! Welcome aboard.', cta_already: "You're already subscribed", cta_invalid: 'Enter a valid email', cta_error: 'Something went wrong.',
          about_label: 'Who we are', about_title: 'About', about_sub: 'Nü metal. Contrast. Purity.',
          about_story_title: 'The Story',
          about_story_p1: 'It all started with a guitar and a dream. Senu, a 14-year-old guitarist, had always imagined creating his own album — a world of sound built from scratch. One day he called his friend Nikita, a 15-year-old bassist, and said: "Let\'s make something real." That conversation became Cleanice.',
          about_story_p2: 'Now we\'re writing our debut album "First Look" — our first look at how nü metal should sound in ' + year + '. It\'s still taking shape, note by note, but every track carries the weight of that first conversation.',
          values_title: 'What Drives Us',
          v1_title: 'Contrast', v1_text: 'Heaviness and purity. Noise and silence. We live on the edge of two extremes.',
          v2_title: 'Energy', v2_text: 'Nü metal is movement. Every track should make your body react.',
          v3_title: 'Purity', v3_text: "Cleanice isn't just a name. We filter sound to its most essential.",
          v4_title: 'Freshness', v4_text: 'First album — first look. We don\'t copy, we create our own sound.',
          members_title: 'Members', m1_role: 'Vocals / Guitar / Frontman / DJ', m2_role: 'Bass / Keys',
          music_label: 'Discography', music_title: 'Music',
          releases_title: 'Releases', filter_all: 'All', filter_albums: 'Albums', filter_singles: 'Singles',
          album_date: year + ' — In progress', not_found: 'Nothing found yet',
          player_tracklist: 'Tracklist', player_desc: 'Our debut album is currently in the writing process. Nü metal, ' + year + '. Hard but clean.',
          coming_soon: 'Coming soon',
          not_found_title: 'Lost in silence', not_found_text: "This page doesn't exist. Maybe it was never meant to.", not_found_btn: 'Back to home',
          footer_copy: '© ' + year + ' Cleanice',
        },
        ru: {
          nav_home: 'Главная', nav_about: 'О нас', nav_music: 'Музыка',
          hero_label: 'Альбом в процессе', hero_sub: 'Ню-метал. First Look — скоро',
          hero_listen: 'Слушать', hero_about: 'О нас',
          card_music_title: 'First Look', card_music_text: 'Наш дебютный альбом в работе. Следите за обновлениями.',
          card_about_title: 'О нас', card_about_text: 'История за звуком. Кто мы и что нами движет.',
          cta_title: 'Будь в курсе', cta_text: 'Получай уведомления о новых релизах, шоу и эксклюзивном контенте.',
          cta_placeholder: 'ваш@email.com', cta_btn: 'Подписаться',
          cta_subscribed: 'Подписан! Добро пожаловать.', cta_already: 'Вы уже подписаны', cta_invalid: 'Введите корректный email', cta_error: 'Что-то пошло не так.',
          about_label: 'Кто мы', about_title: 'О нас', about_sub: 'Ню-метал. Контраст. Чистота.',
          about_story_title: 'История',
          about_story_p1: 'Всё началось с гитары и мечты. Сене — 14-летнему гитаристу — всегда хотелось записать собственный альбом, создать мир звука с нуля. Однажды он позвонил своему другу Никите — 15-летнему басисту — и сказал: "Давай сделаем что-то настоящее." Этот разговор стал началом Cleanice.',
          about_story_p2: 'Сейчас мы пишем дебютный альбом "First Look" — наш первый взгляд на то, как должен звучать ню-метал в ' + year + '-м. Он ещё создаётся, нота за нотой, но каждый трек несёт в себе вес того самого разговора.',
          values_title: 'Что нами движет',
          v1_title: 'Контраст', v1_text: 'Тяжесть и чистота. Шум и тишина. Мы живём на границе двух крайностей.',
          v2_title: 'Энергия', v2_text: 'Ню-метал — это движение. Каждый трек должен заставить тело реагировать.',
          v3_title: 'Чистота', v3_text: 'Cleanice — не просто название. Мы фильтруем звук до самого главного.',
          v4_title: 'Свежесть', v4_text: 'Первый альбом — первый взгляд. Мы не копируем, мы создаём свой звук.',
          members_title: 'Участники', m1_role: 'Вокал / Гитара / Фронтмен / DJ', m2_role: 'Бас / Клавишные',
          music_label: 'Дискография', music_title: 'Музыка',
          releases_title: 'Релизы', filter_all: 'Все', filter_albums: 'Альбомы', filter_singles: 'Синглы',
          album_date: year + ' — В процессе', not_found: 'Ничего не найдено',
          player_tracklist: 'Трек-лист', player_desc: 'Наш дебютный альбом сейчас в процессе написания. Ню-метал, ' + year + '. Жёстко, но чисто.',
          coming_soon: 'Скоро',
          not_found_title: 'Потерялись в тишине', not_found_text: 'Этой страницы не существует. Может, она никогда и не была предназначена.', not_found_btn: 'На главную',
          footer_copy: '© ' + year + ' Cleanice',
        }
      };

      function getLang() { return localStorage.getItem('cleanice_lang') || 'en'; }

      function smoothText(el, finalText, delay) {
        setTimeout(() => {
          el.style.transition = 'filter .15s ease-out, opacity .15s ease-out';
          el.style.filter = 'blur(4px)';
          el.style.opacity = '.4';
          setTimeout(() => {
            el.textContent = finalText;
            el.style.filter = 'blur(0)';
            el.style.opacity = '1';
          }, 150);
        }, delay);
      }

      function setLang(lang) {
        localStorage.setItem('cleanice_lang', lang);
        document.documentElement.lang = lang === 'ru' ? 'ru' : 'en';
        document.querySelectorAll('[data-i18n]').forEach((el, i) => {
          const key = el.getAttribute('data-i18n');
          const newText = i18n[lang][key];
          if (newText && newText !== el.textContent) smoothText(el, newText, i * 25);
        });
        document.querySelectorAll('[data-i18n-placeholder]').forEach((el, i) => {
          const key = el.getAttribute('data-i18n-placeholder');
          if (i18n[lang][key]) setTimeout(() => { el.placeholder = i18n[lang][key]; }, i * 25);
        });
        const langBtn = document.getElementById('langSwitcher');
        if (langBtn) smoothText(langBtn, lang === 'en' ? 'EN' : 'RU', 0);
      }

      function getTheme() { return localStorage.getItem('cleanice_theme') || 'dark'; }
      function setTheme(theme) {
        localStorage.setItem('cleanice_theme', theme);
        document.body.classList.toggle('light', theme === 'light');
        document.querySelector('meta[name="theme-color"]')?.setAttribute('content', theme === 'light' ? '#F5F3EF' : '#090909');
      }

      setLang(getLang());
      setTheme(getTheme());

      document.getElementById('langSwitcher')?.addEventListener('click', () => {
        setLang(getLang() === 'en' ? 'ru' : 'en');
      });
      document.getElementById('themeSwitcher')?.addEventListener('click', () => {
        setTheme(getTheme() === 'dark' ? 'light' : 'dark');
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --background: #090909;
    --primary: #FFFFFF;
    --text: #F5F5F5;
    --text-secondary: #B5B5B5;
    --border: rgba(255,255,255,.08);
    --card-bg: rgba(255,255,255,.02);
    --nav-bg: rgba(18,18,18,.75);
    --radius-card: 18px;
    --radius-btn: 12px;
    --radius-input: 10px;
    --radius-lg: 24px;
    --font-serif: 'Instrument Serif', Georgia, serif;
    --font-sans: 'Inter', system-ui, sans-serif;
  }

  body.light {
    --background: #F5F3EF;
    --primary: #090909;
    --text: #111111;
    --text-secondary: #555555;
    --border: rgba(0,0,0,.08);
    --card-bg: rgba(0,0,0,.03);
    --nav-bg: rgba(245,243,239,.8);
  }

  body.light .grain { opacity: .04; }
  body.light .glow--top { background: radial-gradient(circle, rgba(0,0,0,.04) 0%, transparent 70%); }
  body.light .page-transition { background: var(--background); }
  body.light .btn--primary { background: rgba(0,0,0,.05); border: 1px solid rgba(0,0,0,.12); color: var(--text); }
  body.light .btn--primary:hover { background: rgba(0,0,0,.1); box-shadow: 0 0 30px rgba(0,0,0,.08); }
  body.light .btn--ghost { color: var(--text-secondary); }
  body.light .nav { box-shadow: 0 8px 32px rgba(0,0,0,.08), 0 0 0 1px rgba(0,0,0,.04) inset; }
  body.light h1, body.light h2, body.light h3, body.light h4 { color: var(--text); }
  body.light .footer__copy { color: var(--text-secondary); opacity: .4; }
  body.light ::-webkit-scrollbar-thumb { background: rgba(0,0,0,.15); }
  body.light ::-webkit-scrollbar-track { background: var(--background); }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html {
    font-family: var(--font-sans);
    background: var(--background);
    color: var(--text);
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100vh;
    background: radial-gradient(circle at 50% 0%, #121212 0%, #090909 55%, #040404 100%);
    overflow-x: hidden;
    position: relative;
    transition: background .5s ease-out;
  }

  body.light {
    background: radial-gradient(circle at 50% 0%, #FDFCFA 0%, #F5F3EF 55%, #EDE9E3 100%);
  }

  main { min-height: calc(100vh - 200px); }
  a { color: inherit; text-decoration: none; }

  /* Focus styles */
  :focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }

  /* Skip to content */
  .sr-only {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0); border: 0;
  }
  .sr-only:focus {
    position: fixed; top: 1rem; left: 50%; transform: translateX(-50%);
    z-index: 99999; padding: .5rem 1rem;
    background: var(--primary); color: var(--background);
    border-radius: var(--radius-btn);
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
    .page-transition { display: none; }
    .grain { display: none; }
    .glow { display: none; }
  }

  .section-title {
    font-family: var(--font-serif);
    font-weight: 300;
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    letter-spacing: .02em;
    margin-bottom: 2rem;
  }

  .section-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Page transition */
  .page-transition {
    position: fixed;
    inset: 0;
    background: var(--background);
    z-index: 9998;
    pointer-events: none;
    opacity: 1;
    animation: pageIn 1s cubic-bezier(.22,1,.36,1) forwards;
  }

  @keyframes pageIn { from { opacity: 1; } to { opacity: 0; } }
  @keyframes pageOut { from { opacity: 0; } to { opacity: 1; } }

  /* Grain */
  .grain {
    position: fixed; inset: 0; z-index: 9999; pointer-events: none; opacity: .1;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat; background-size: 128px 128px;
  }

  /* Glow */
  .glow { position: fixed; border-radius: 50%; pointer-events: none; z-index: 0; }
  .glow--top {
    top: -200px; left: 50%; transform: translateX(-50%); width: 800px; height: 600px;
    background: radial-gradient(circle, rgba(255,255,255,.06) 0%, transparent 70%);
    animation: glowPulse 6s ease-in-out infinite;
  }
  @keyframes glowPulse { 0%, 100% { opacity: .6; } 50% { opacity: 1; } }

  /* Nav */
  .nav {
    position: fixed; top: 1rem; left: 50%; z-index: 100;
    display: grid; grid-template-columns: 30px 1fr 30px; align-items: center; justify-content: center;
    padding: .65rem 1rem; width: min(90vw, 420px);
    border-radius: 100px; backdrop-filter: blur(24px) saturate(1.4);
    background: var(--nav-bg); border: 1px solid var(--border);
    box-shadow: 0 8px 32px rgba(0,0,0,.4), 0 0 0 1px rgba(255,255,255,.04) inset;
    animation: navAppear .6s cubic-bezier(.22,1,.36,1) both;
    transition: background .4s ease-out, border-color .4s ease-out;
  }

  @keyframes navAppear {
    from { opacity: 0; transform: translateX(-50%) translateY(-12px) scale(.95); }
    to { opacity: 1; transform: translateX(-50%) translateY(0) scale(1); }
  }

  .nav__switcher {
    flex-shrink: 0; width: 30px; height: 30px;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-sans); font-size: .65rem; font-weight: 400;
    letter-spacing: .06em; color: var(--text-secondary);
    background: rgba(255,255,255,.06); border: 1px solid var(--border);
    border-radius: 50%; cursor: pointer;
    transition: all .25s cubic-bezier(.22,1,.36,1);
  }
  body.light .nav__switcher { background: rgba(0,0,0,.06); }
  .nav__switcher:hover { color: var(--primary); background: rgba(255,255,255,.1); transform: scale(1.1); }
  body.light .nav__switcher:hover { background: rgba(0,0,0,.1); }
  .nav__switcher:active { transform: scale(.92); }

  .icon-sun { display: none; }
  body.light .icon-sun { display: block; }
  body.light .icon-moon { display: none; }

  .nav__links { display: flex; gap: 1.5rem; justify-content: center; }

  .nav__link {
    font-size: .72rem; font-weight: 300; letter-spacing: .06em; text-transform: uppercase;
    color: var(--text-secondary); transition: color .3s ease-out;
    position: relative; padding: .15rem 0;
  }
  .nav__link--active { color: var(--primary); }
  .nav__link::after {
    content: ''; position: absolute; bottom: -4px; left: 0; width: 0; height: 1px;
    background: var(--primary); transition: width .3s cubic-bezier(.22,1,.36,1);
  }
  .nav__link--active::after { width: 100%; }
  .nav__link:hover { color: var(--primary); }
  .nav__link:hover::after { width: 100%; }

  /* Buttons */
  .btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: .85rem 2rem; font-family: var(--font-sans); font-size: .85rem;
    font-weight: 400; letter-spacing: .04em; border-radius: var(--radius-btn);
    cursor: pointer; transition: all .25s cubic-bezier(.22,1,.36,1); border: none; text-decoration: none;
  }
  .btn:active { transform: scale(.96); }
  .btn--primary { background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.12); color: white; }
  .btn--primary:hover { background: rgba(255,255,255,.1); box-shadow: 0 0 24px rgba(255,255,255,.12); border-color: rgba(255,255,255,.2); }
  .btn--ghost { background: transparent; color: var(--text-secondary); }
  .btn--ghost:hover { color: var(--primary); }
  .btn:disabled { opacity: .5; cursor: not-allowed; transform: none; }

  /* Footer */
  .footer { border-top: 1px solid var(--border); padding: 3rem 5vw; }
  .footer__inner { max-width: 1200px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 1.5rem; }
  .footer__logo-text { font-family: var(--font-serif); font-weight: 300; font-size: .9rem; letter-spacing: .25em; text-transform: uppercase; color: var(--text-secondary); opacity: .5; user-select: none; }
  .footer__links { display: flex; gap: 2rem; }
  .footer__links a { font-size: .8rem; font-weight: 300; color: var(--text-secondary); letter-spacing: .04em; transition: color .25s ease-out, transform .25s ease-out; display: inline-block; }
  .footer__links a:hover { color: var(--primary); transform: translateY(-2px); }
  .footer__copy { font-size: .75rem; color: var(--text-secondary); opacity: .4; letter-spacing: .04em; }

  /* Animations */
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes blurIn { from { opacity: 0; filter: blur(8px); } to { opacity: 1; filter: blur(0); } }

  /* Smooth fade-in */
  .fade-in { opacity: 0; animation: fadeIn .7s cubic-bezier(.22,1,.36,1) forwards; animation-delay: var(--delay, 0s); }

  /* Scroll reveal — smooth fade */
  .reveal { opacity: 0; transform: translateY(30px); transition: opacity .7s cubic-bezier(.22,1,.36,1), transform .7s cubic-bezier(.22,1,.36,1); transition-delay: var(--delay, 0s); }
  .reveal--blur { opacity: 0; filter: blur(8px); transition: opacity .7s cubic-bezier(.22,1,.36,1), filter .7s cubic-bezier(.22,1,.36,1); transition-delay: var(--delay, 0s); }
  .reveal--scale { opacity: 0; transform: scale(.97); transition: opacity .7s cubic-bezier(.22,1,.36,1), transform .7s cubic-bezier(.22,1,.36,1); transition-delay: var(--delay, 0s); }
  .reveal.is-visible, .reveal--blur.is-visible, .reveal--scale.is-visible { opacity: 1; transform: translateY(0) scale(1); filter: blur(0); }

  /* Entrance (hero load) */
  .anim-fade-in { animation: fadeIn .5s cubic-bezier(.22,1,.36,1) both; }
  .anim-fade-up { animation: fadeUp .6s cubic-bezier(.22,1,.36,1) both; }
  .anim-blur-in { animation: blurIn .8s cubic-bezier(.22,1,.36,1) both; }
  .delay-1 { animation-delay: .1s; } .delay-2 { animation-delay: .2s; }
  .delay-3 { animation-delay: .3s; } .delay-4 { animation-delay: .4s; }
  .delay-5 { animation-delay: .5s; } .delay-6 { animation-delay: .6s; }
  .delay-7 { animation-delay: .7s; } .delay-8 { animation-delay: .8s; }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--background); }
  ::-webkit-scrollbar-thumb { background: rgba(255,255,255,.15); border-radius: 2px; }

  @media (max-width: 768px) {
    .nav { padding: .45rem .7rem; width: min(92vw, 340px); grid-template-columns: 24px 1fr 24px; }
    .nav__links { gap: 1rem; }
    .nav__link { font-size: .6rem; }
    .nav__switcher { width: 24px; height: 24px; font-size: .55rem; }
    .footer { padding: 1.5rem 1rem; }
    .footer__links { gap: 1rem; flex-wrap: wrap; justify-content: center; }
    .section-container { padding: 0 1.25rem; }
  }

  @media (min-width: 768px) {
    .section-container { padding: 0 2rem; }
  }
</style>

<script>
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.reveal, .reveal--blur, .reveal--scale').forEach(el => {
    if (prefersReducedMotion) { el.classList.add('is-visible'); }
    else { observer.observe(el); }
  });

  document.addEventListener('contextmenu', e => { if (e.target.tagName === 'IMG') e.preventDefault(); });
  document.addEventListener('dragstart', e => { if (e.target.tagName === 'IMG') e.preventDefault(); });

  document.addEventListener('click', (e) => {
    const link = (e.target as HTMLElement).closest('a[href^="/"]');
    if (!link) return;
    const href = link.getAttribute('href');
    const current = window.location.pathname.replace(/\/$/, '') || '/';
    const target = (href || '').replace(/\/$/, '') || '/';
    if (target === current) return;
    e.preventDefault();
    if (prefersReducedMotion) { window.location.href = href!; return; }
    const t = document.querySelector('.page-transition');
    if (t) {
      t.style.animation = 'none'; t.style.opacity = '0';
      void t.offsetWidth;
      t.style.animation = 'pageOut .6s cubic-bezier(.22,1,.36,1) forwards';
    }
    setTimeout(() => { window.location.href = href!; }, 550);
  });
</script>
